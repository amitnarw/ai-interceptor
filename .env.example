# MiniMax API
MINIMAX_API_KEY=your_minimax_api_key_here

# Telegram Bot (from BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Server
PROXY_PORT=4000

# Mode (desk | away)
MODE=desk

# Auto-reject timeout in milliseconds (10 minutes)
AUTO_REJECT_TIMEOUT_MS=600000

# Redis (optional - uses ioredis-mock if not configured)
# USE_REDIS_MOCK=true
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
